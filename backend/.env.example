# ===========================================
# MACROMETRICS ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://username:password@localhost:5432/macrometrics

# ===========================================
# SECURITY
# ===========================================
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-change-this-in-production

# ===========================================
# USDA FOOD DATABASE
# Get free API key: https://fdc.nal.usda.gov/api-guide.html
# ===========================================
NUTRITION_API_KEY=your-usda-api-key

# ===========================================
# AI INTEGRATION (Choose one)
# ===========================================
# Option 1: Ollama (Local - Free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Option 2: Google Gemini API (Cloud)
# GEMINI_API_KEY=your-gemini-api-key

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_ENV=development
DEBUG=true